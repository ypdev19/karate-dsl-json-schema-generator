{
  "name": "karate-json-schema-converter",
  "version": "1.0.0",
  "description": "A free tool to convert JSON to valid Karate DSL compatible JSON Schema",
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules package-lock.json",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "ava"
  },
  "ava": {
    "files": [
      "index.test.js"
    ],
    "extensions": [
      "js"
    ],
    "timeout": "60s"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ypdev19/karate-dsl-json-schema-generator.git"
  },
  "keywords": [
    "json",
    "karate-dsl",
    "schema",
    "generator",
    "react",
    "vite"
  ],
  "author": "ypdev19",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ypdev19/karate-dsl-json-schema-generator/issues"
  },
  "homepage": "https://github.com/ypdev19/karate-dsl-json-schema-generator#readme",
  "dependencies": {
    "ace-builds": "^1.43.6",
    "bootstrap": "^5.3.0",
    "i18next": "^26.0.3",
    "react": "^18.3.1",
    "react-ace": "^10.1.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "react-icons": "^5.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "ava": "^6.0.0",
    "vite": "^5.0.0"
  }
}
